from fastapi import FastAPI

app = FastAPI(title="{{ name }}")


@app.get("/")
def root():
    return {"service": "{{ name }}"}


@app.get("/healthz")
def liveness():
    return {"status": "ok"}


@app.get("/readyz")
def readiness():
    return {"status": "ready"}


if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port={{ port }})
